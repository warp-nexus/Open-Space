<!-- open-space edit start -->
<PanelContainer xmlns="https://spacestation14.io">
    <BoxContainer Orientation="Vertical" Margin="6" SeparationOverride="4">
        <BoxContainer Orientation="Horizontal" SeparationOverride="6">
            <SpriteView Name="EntityView"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MinSize="32 32" />
            <BoxContainer Orientation="Vertical" HorizontalExpand="True">
                <Label Name="NameLabel" ClipText="True" />
                <Label Name="CountLabel" Modulate="#b9b9b9" />
            </BoxContainer>
        </BoxContainer>
        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Right" SeparationOverride="4">
            <Button Name="DispenseOneButton" Text="{Loc 'smart-fridge-component-dispense-one'}" />
            <LineEdit Name="AmountLineEdit"
                      HorizontalAlignment="Right"
                      PlaceHolder="{Loc 'smart-fridge-component-custom-amount-placeholder'}"
                      Text="1"
                      MinWidth="70" />
            <Button Name="DispenseAllButton" Text="{Loc 'smart-fridge-component-dispense-all'}" />
        </BoxContainer>
    </BoxContainer>
</PanelContainer>
<!-- open-space edit end -->
