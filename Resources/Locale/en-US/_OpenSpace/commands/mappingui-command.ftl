cmd-mappingui-desc = Create a paused map and switch your client into MappingUI.
cmd-mappingui-help = Usage: mappingui [MapID]
cmd-mappingui-error = An error occurred when creating the mapping UI map.
cmd-mappingui-success = Created MappingUI map with id {$mapId}.
cmd-mappingui-failure-integer = {$arg} is not a valid integer.
cmd-mappingui-nullspace = You cannot load into map 0.
cmd-mappingui-exists = Map {$mapId} already exists.
cmd-hint-mappingui-id = [MapID]

cmd-mappinguiclientsidesetup-desc = Sets up the client-side MappingUI screen, lighting, FOV, and mapping helpers.
cmd-mappinguiclientsidesetup-help = Usage: mappinguiclientsidesetup

cmd-mappinguigridtp-desc = Teleport yourself to the center of a MappingUI grid.
cmd-mappinguigridtp-help = Usage: mappinguigridtp <grid>
cmd-mappinguigridset-desc = Change MappingUI grid name and radar color.
cmd-mappinguigridset-help = Usage: mappinguigridset <grid> <#RRGGBB> [name]
cmd-mappinguigrid-invalid = Grid {$grid} does not exist.
cmd-mappinguigrid-no-player = You must have an attached entity.
cmd-mappinguigrid-color-invalid = {$color} is not a valid hex color.
cmd-mappinguigridset-success = Grid settings updated.
cmd-hint-mappinguigrid = <grid>
cmd-hint-mappinguigrid-name = [name]
