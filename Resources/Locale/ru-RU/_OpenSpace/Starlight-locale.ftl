loadout-group-nanotrasenrepresentative-head = Представитель NT, голова

# Head
ent-ClothingHeadHatCapNtrep = фуражка представителя NT
    .desc = Фуражка правосудия над командованием!

ent-ClothingHeadHatBeretBlueShield = берет офицера "Синий щит"
    .desc = { ent-ClothingHeadBase.desc }

ent-ClothingHeadHatBlueShieldSheriff = охотник за головами "Синиего щита"
    .desc = Когда те, кто под вашей защитой, не хотят, чтобы их выследили.

ent-ClothingHeadHatNTRTophat = цилиндр представителя NT
    .desc = Роскошный чёрный цилиндр ручной работы для представителя NanoTrasen. Выглядит дорого.

ent-ClothingHeadHatNTREliteTophat = элитный цилиндр представителя NT
    .desc = Дорогой на вид чёрный цилиндр. Золотое тиснение с логотипом NanoTrasen спереди идеально подходит для представителя мегакорпорации.

ent-ClothingHeadHatCCberet = берет ЦентКом
    .desc = Зелёный берет. Как и любой другой, но зелёный, и вам его нельзя.

ent-ClothingHeadHatCCSheriffhat = шляпа шерифа ЦентКома
    .desc = Шляпа шерифа в фирменных цветах ЦК. Один взгляд на неё заставит ассистента дважды подумать, прежде чем пробираться на дебрифинг.



# Eyes
ent-ClothingEyesSunGlassesHudSkill = солнцезащитные очки-визор
    .desc = Солнцезащитные очки со встроенным визором, отображающим трудовую книжку находящихся поблизости членов экипажа NT.

ent-ClothingEyesGlassesBlueShield = очки офицера "Синего щита"
    .desc = Инновационные синие линзы защищают глаза от вспышек света и имеют встроенный визор.

ent-ClothingEyesHudBlueShield = визор "Синего щита"
    .desc = Инновационный дисплей, сканирующий гуманоидов в поле зрения и предоставляющий точные данные об их статусе ID, криминальной истории и медицинских показателях.

ent-ClothingEyesEyepatchHudBlueShield = повязка на глаз "Синего щита"
    .desc = { ent-ClothingEyesHudBlueShield.desc } Для истинных патриотов.

ent-ClothingEyesEyepatchHudBlueShieldFlipped = { ent-ClothingEyesEyepatchHudBlueShield }
    .desc = { ent-ClothingEyesEyepatchHudBlueShield.desc }

ent-ClothingEyesHudSkills = продвинутый визор
    .desc = Визор отображающий трудовую книжку находящихся поблизости членов экипажа NT.

ent-ClothingEyesHudCentComm = визор офицера ЦентКом
    .desc = Инновационный дисплей, сканирующий гуманоидов в поле зрения и предоставляющий точные данные об их статусе ID, криминальной записи и медицинских показателях.

ent-ClothingEyesNTRMonocle = монокль представителя NT
    .desc = Роскошный монокль, который также функционирует как HUD, чтобы стиль не мешал функциональности.



# Ears
ent-ClothingHeadsetMagistrate = гарнитура магистрата
    .desc = Гарнитура, позволяющая АВД услышать последние слова капитана.

ent-ClothingHeadsetAltBSO = полноразмерная гарнитура "Синего щита"
    .desc = { ent-ClothingHeadsetAlt.desc }



# Belt
ent-ClothingBeltBlueShieldWebbing = РПС "Синего щита"
    .desc = Тактическое снаряжение, способное вместить множество предметов для спасения жизней командования.

ent-ClothingBeltBlueShieldWebbingFilled = РПС "Синего щита"
    .desc = Тактическое снаряжение, способное вместить множество предметов для спасения жизней командования.

ent-ClothingBeltBlueShieldMedicalBelt = медицинский пояс "Синего щита"
    .desc = Тактический пояс, способный вместить множество медикаментов для спасения жизней командования.

ent-ClothingBeltBlueShieldMedicalBeltFilled = медицинский пояс "Синего щита"
    .desc = Тактический пояс, способный вместить множество медикаментов для спасения жизней командования.

# Back
ent-ClothingBackpackBlueShield = рюкзак "Синего щита"
    .desc = { ent-ClothingBackpack.desc }

ent-ClothingBackpackDuffelBlueShield = вещмешок "Синего щита"
    .desc = { ent-ClothingBackpackDuffel.desc }

ent-ClothingBackpackSatchelBlueShield = сумка "Синего щита"
    .desc = Полезна для хранения всего, что нужно для оперативной работы офицера "Синего щита"!

ent-ClothingBackpackSatchelCentcomm = сумка оператора Центрального Командования
    .desc = Весьма стильная сумка, покрытая настоящим золотом, выдаваемая операторам Центрального Командования.



# Uniforms
ent-ClothingUniformJumpskirtNtrep = юбка-комбинезон представителя NT
    .desc = Та самая юбка, которую лучше не видеть.

ent-ClothingUniformJumpskirtNtrepTurtleneck = юбка-комбинезон представителя NT с водолазкой
    .desc = Для более повседневного вида во время работы.

ent-ClothingUniformJumpskirtBlueShield = юбка-комбинезон офицера "Синего щита"
    .desc = Комбинезон прославленного телохранителя.

ent-ClothingUniformJumpskirtEliteBlueShield = юбка-комбинезон элитного офицера "Синего щита"
    .desc = Комбинезон элитного бойца "Синего щита". Чтобы достичь такого уровня, вы должны были защитить командование от [УДАЛЕНО] угрозы.

ent-ClothingUniformJumpskirtBlueShieldSkirt = юбка-карандаш офицера "Синего щита"
    .desc = Рубашка с воротником и юбка-карандаш для офицера "Синего щита", предпочитающего деловой повседневный стиль.

ent-MagistrateUniformSkirt = юбка-комбинезон магистрата
    .desc = { ent-ClothingUniformSkirtBase.desc }

ent-MagistrateUniformSuit = комбинезон магистрата
    .desc = { ent-ClothingUniformBase.desc }

ent-ClothingUniformJumpsuitNtrep = костюм представителя NT
    .desc = Тот самый костюм, который лучше не видеть.

ent-ClothingUniformJumpsuitNtrepFormal = официальный костюм представителя NT
    .desc = Тот самый костюм, который лучше не видеть.

ent-ClothingUniformJumpsuitNtrepTurtleNeck = комбинезон представителя NT с водолазкой
    .desc = Для более повседневного вида во время работы.

ent-ClothingUniformJumpsuitNtrepNoble = дворянский комбинезон представителя NT
    .desc = Более классический и элегантный стиль одежды, созданный подражать моде старой земной аристократии.

ent-ClothingUniformJumpsuitBlueShield = костюм офицера "Синего щита"
    .desc = Костюм прославленного телохранителя.

ent-ClothingUniformJumpsuitEliteBlueShield = костюм элитного офицера "Синего щита"
    .desc = Костюм элитного бойца "Синего щита". Чтобы достичь такого уровня, вы должны были защитить командование от [УДАЛЕНО] угрозы.

ent-ClothingUniformJumpsuitBlueShieldShirt = официальный костюм офицера "Синего щита"
    .desc = Рубашка с воротником и брюки для офицера "Синего щита", предпочитающего деловой повседневный стиль.

ent-ClothingUniformJumpsuitFormalBlueShield = парадный костюм офицера "Синего щита"
    .desc = Текстильный комбинезон, в некоторых местах усиленный толстой кожей.



# OuterClothing
ent-ClothingOuterArmorBlueShield = бронежилет офицера "Синего щита"
    .desc = { ent-ClothingOuterArmorBasic.desc }

ent-ClothingOuterCoatBlueShield = пальто "Синего щита"
    .desc = Пальто, которое носят офицеры "Синего щита", не боящиеся холода. Сильно укреплено на случай, если дипломатия не поможет.

ent-ClothingOuterCoatNtrep = пиджак представителя NT
    .desc = Роскошный чёрный пиджак, стандартная экипировка представителей NanoTrasen.

ent-ClothingOuterCoatNtrepOpen = { ent-ClothingOuterCoatNtrep }
    .desc = { ent-ClothingOuterCoatNtrep.desc }



# Neck
ent-ClothingNeckCloakBsoElite = плащ элитного офицера "Синего щита"
    .desc = Плащ элитного офицера "Синего щита", изготовленный из новейшей композитной светящейся ткани. Настоящий "Синий щит" не боится сиять в темноте!

ent-ClothingNeckCloakBsoCape = парадная накидка офицера "Синего щита"
    .desc = Невероятно большое пальто, которым владеют только самые опытные сотрудники "Синего щита". Говорят, что рукава этой одежды никогда не использовались по назначению.

ent-ClothingNeckCloakBsoPoncho = пончо офицера "Синего щита"
    .desc = Говорят, что этот тип пончо был фирменной одеждой легендарного ОСЩ без имени.

ent-ClothingNeckTornCapeGray = серый рваный плащ
    .desc = Рваный плащ. Вы выглядите потрясающе.

ent-ClothingNeckTornCapeBlue = синий рваный плащ
    .desc = { ent-ClothingNeckTornCapeGray.desc }

ent-ClothingNeckTornCapeGreen = зелёный рваный плащ
    .desc = { ent-ClothingNeckTornCapeGray.desc }

ent-ClothingNeckTornCapeOrange = оранжевый рваный плащ
    .desc = { ent-ClothingNeckTornCapeGray.desc }

ent-ClothingNeckTornCapeRed = красный рваный плащ
    .desc = { ent-ClothingNeckTornCapeGray.desc }

ent-ClothingNeckTornCapePurple = фиолетовый рваный плащ
    .desc = { ent-ClothingNeckTornCapeGray.desc }

ent-ClothingNeckTornCapeBrown = коричневый рваный плащ
    .desc = { ent-ClothingNeckTornCapeGray.desc }



# Shoes
ent-ClothingShoesHighheelShoes = туфли на каблуках
    .desc = Шикарные туфли для случаев, когда хочется выглядеть стильно и быть замеченной.



# PDA
ent-MagistratePDA = КПК магистрата
    .desc = { ent-BasePDA.desc }

ent-NanoTrasenRepresentativePDA = КПК представителя NanoTrasen
    .desc = { ent-BasePDA.desc }

ent-BlueShieldPDA = КПК офицера "Синего щита"
    .desc = Поставляется со встроенным медицинским ПО для оценки ран командного состава после того, как вы их героически спасете.

ent-VeteranBlueShieldPDA = КПК ветерана "Синего щита"
    .desc = { ent-BlueShieldPDA.desc }

ent-NTNCBlueShieldPDA = КПК морского офицера
    .desc = { ent-BasePDA.desc }

ent-NTNCCSPDA = КПК морского офицера NT NC
    .desc = { ent-BasePDA.desc }



# HardSuit
ent-ClothingOuterHardsuitBlueshield = скафандр "Синего щита"
    .desc = Высокотехнологичный скафандр, идеально подходящий для того, чтобы прыгнуть под пулю вместо господина Прези... э-э, Капитана.

ent-ClothingOuterHardsuitNtrep = скафандр представителя NT
    .desc = Раньше он был синим, но от слишком большого количества премиальных сигар он стал табачно-коричневым.

ent-ClothingOuterBattlesuitClown = боевой скафандр клоуна
    .desc = Смешной костюм, защищающий от опасных сред с низким давлением. Имеет дополнительный слой брони.

ent-ClothingOuterHardsuitInfiltration = инфильтрационный скафандр Синдиката
    .desc = Выбор операторов Синдиката! Этот скафандр, помимо прочности, был разработан с упором на скрытность.

ent-ClothingOuterHardsuitSecurityExperimental = экспериментальный скафандр службы безопасности
    .desc = Высокотехнологичный скафандр, призванный со временем заменить стандартный костюм СБ. Оснащён системами ID-Lock и Gun-Lock. Ходят слухи, что первый прототип был украден Синдикатом...

# HardSuit Helmet
ent-ClothingHeadHelmetHardsuitBlueshield = шлем скафандра "Синего щита"
    .desc = { ent-ClothingHeadHardsuitBase.desc }

ent-ClothingHeadHelmetHardsuitNtrep = шлем скафандра представителя NT
